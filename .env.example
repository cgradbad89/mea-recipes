# Firebase / Next.js Setup
# NEXT_PUBLIC_FIREBASE_API_KEY=...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=...
# ... etc ...

# Vercel Cron Job Secrets for MyFitnessPal Sync
# Generate a random string for this:
CRON_SECRET=your_secure_cron_secret
# Your Firebase User ID to associate the data with:
MFP_SYNC_UID=your_firebase_uid

# MyFitnessPal Session Details (Requires manual updating when expired)
# The sync scrapes the classic diary page HTML
# (https://www.myfitnesspal.com/food/diary/{MFP_USERNAME}?date=YYYY-MM-DD) —
# it does not call a documented API — so only the session cookie + User-Agent
# are needed to authenticate the page load.
MFP_SESSION_COOKIE="your_full_cookie_string"
# The username URL path segment from your diary URL (e.g. "folstromjohn"):
MFP_USERNAME="your_mfp_username"
# The exact User-Agent header from the same browser request you copied the
# cookie from (kept as an env var so it can change without a redeploy):
MFP_USER_AGENT="your_browser_user_agent_string"
# Optional: set to "true" to enable verbose troubleshooting logs (presence flags,
# lengths, fetch URL/header keys). Omit or set anything else to keep the job quiet.
# MFP_DEBUG=true
