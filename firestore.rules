rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// MEA Recipes — Firestore security rules (version-controlled copy)
//
// ⚠️ RECONCILE-WITH-CONSOLE NOTE
// This file was RECONSTRUCTED from the collection paths actually used in the
// codebase (grep of `collection(db, …)` / `doc(db, …)` across lib/, hooks/,
// app/, components/). The authoritative ruleset still lives in the Firebase
// console for project `malignant-metro`. Before deploying, paste the current
// console rules over this file (or diff them) so the two cannot drift again.
// The reason this file exists: a new collection's path was once not covered by
// any rule, causing a silent client-side write failure. Keeping rules in the
// repo means future collection additions get a matching rule in the same change.
//
// App is effectively single-user (admin: folstromjohn@gmail.com). These rules
// scope each user's private data to their own uid; the shared `recipes`
// library is readable by any signed-in user and written on publish/edit.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Shared recipe library — recipes/{id}. Read by any signed-in user; written
    // by saveRecipe() on publish/edit (incl. the nutrition object merged on by
    // auto-nutrition-on-publish and the manual "Calculate nutrition" retry).
    match /recipes/{recipeId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // ── Per-user private data (owner-only) ──────────────────────────────────
    // Nutrition tracker subtree: users/{uid}/nutrition/root/{log,goals,savedFoods}.
    // This explicit recursive rule is the one added in the console after the
    // silent-write incident — kept named so future nutrition subcollections stay
    // covered even if the broad owner rule below is later tightened.
    match /users/{uid}/nutrition/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // Everything else under a user's own document: recipeQueue, recipes/root/meta,
    // recipes/root/favorites, pantry/root/{weekPlans,groceryItems,savedGroceryItems}.
    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // Shared week plans ("everyone's plan this week"). Each user writes only their
    // own slot; signed-in collaborators may read the week.
    match /sharedWeekPlans/{weekID} {
      allow read: if signedIn();
      match /users/{uid} {
        allow read: if signedIn();
        allow write: if isOwner(uid);
      }
    }
  }
}
